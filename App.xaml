<Application x:Class="AppPrestamos.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AppPrestamos.ViewModels"
             xmlns:v="clr-namespace:AppPrestamos.Views"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Colores -->
        <Color x:Key="Azul">#3B82F6</Color>
        <Color x:Key="Verde">#10B981</Color>
        <Color x:Key="Naranja">#F59E0B</Color>
        <Color x:Key="Morado">#8B5CF6</Color>
        <Color x:Key="Rojo">#EF4444</Color>

        <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0F172A" Offset="0"/>
            <GradientStop Color="#1E293B" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="SombraTarjeta" BlurRadius="20" Opacity="0.07" Direction="270" Color="#000000"/>
        <DropShadowEffect x:Key="SombraSidebar" BlurRadius="25" Opacity="0.2" Direction="270" Color="#000000"/>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Iconos del men\u00fa -->
        <Geometry x:Key="IconDashboard">M3,3 L9,3 L9,9 L3,9 Z M11,3 L17,3 L17,9 L11,9 Z M3,11 L9,11 L9,17 L3,17 Z M11,11 L17,11 L17,17 L11,17 Z</Geometry>
        <Geometry x:Key="IconClientes">M9,9 C11.21,9 13,7.21 13,5 C13,2.79 11.21,1 9,1 C6.79,1 5,2.79 5,5 C5,7.21 6.79,9 9,9 Z M9,11 C6.33,11 1,12.34 1,15 L1,17 L17,17 L17,15 C17,12.34 11.67,11 9,11 Z</Geometry>
        <Geometry x:Key="IconPrestamos">M10,2 C4.48,2 0,6.48 0,12 C0,17.52 4.48,22 10,22 C15.52,22 20,17.52 20,12 C20,6.48 15.52,2 10,2 Z M11,17 L9,17 L9,15 L11,15 Z M11,13 L9,13 L9,7 L11,7 Z</Geometry>
        <Geometry x:Key="IconCuotas">M17,3 L16,3 L16,1 L14,1 L14,3 L6,3 L6,1 L4,1 L4,3 L3,3 C1.89,3 1,3.89 1,5 L1,19 C1,20.1 1.89,21 3,21 L17,21 C18.1,21 19,20.1 19,19 L19,5 C19,3.89 18.1,3 17,3 Z M17,19 L3,19 L3,8 L17,8 Z</Geometry>
        <Geometry x:Key="IconPagos">M18,4 L4,4 C2.89,4 2,4.89 2,6 L2,18 C2,19.11 2.89,20 4,20 L18,20 C19.11,20 20,19.11 20,18 L20,6 C20,4.89 19.11,4 18,4 Z M18,18 L4,18 L4,12 L18,12 Z M18,8 L4,8 L4,6 L18,6 Z</Geometry>
        <Geometry x:Key="IconReportes">M4,9.2 L7,9.2 L7,19 L4,19 Z M9.6,5 L12.6,5 L12.6,19 L9.6,19 Z M15.2,11 L18.2,11 L18.2,19 L15.2,19 Z</Geometry>
        <Geometry x:Key="IconBackup">M5,20 L19,20 L19,18 L5,18 Z M13,14 L13,5 L15,5 L12,2 L9,5 L11,5 L11,14 Z</Geometry>
        <Geometry x:Key="IconAuditoria">M19,3 L5,3 C3.89,3 3,3.89 3,5 L3,19 C3,20.1 3.89,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.89 20.1,3 19,3 Z M10,17 L8,17 L8,11 L10,11 Z M14,17 L12,17 L12,7 L14,7 Z M18,17 L16,17 L16,13 L18,13 Z</Geometry>
        <Geometry x:Key="IconSimulador">M7,2 L3,2 L3,22 L7,22 Z M13,2 L9,2 L9,22 L13,22 Z M17,2 L15,2 L15,22 L17,22 Z M21,2 L19,2 L19,22 L21,22 Z</Geometry>
        <Geometry x:Key="IconCalendario">M19,4 L18,4 L18,2 L16,2 L16,4 L8,4 L8,2 L6,2 L6,4 L5,4 C3.89,4 3,4.89 3,6 L3,20 C3,21.1 3.89,22 5,22 L19,22 C20.1,22 21,21.1 21,20 L21,6 C21,4.89 20.1,4 19,4 Z M19,20 L5,20 L5,9 L19,9 Z</Geometry>

        <Style x:Key="NavItemBase" TargetType="Border">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplates para navegaci\u00f3n -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
            <v:ClientesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PrestamosViewModel}">
            <v:PrestamosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CuotasViewModel}">
            <v:CuotasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PagosViewModel}">
            <v:PagosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportesViewModel}">
            <v:ReportesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupViewModel}">
            <v:BackupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditoriaViewModel}">
            <v:AuditoriaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SimuladorViewModel}">
            <v:SimuladorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalendarioViewModel}">
            <v:CalendarioView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <v:ProfileView/>
        </DataTemplate>
    </Application.Resources>
</Application>
