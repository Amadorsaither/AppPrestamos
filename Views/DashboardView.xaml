<UserControl x:Class="AppPrestamos.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="#F1F5F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
        <StackPanel Margin="30,25,30,30">

            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard" FontSize="30" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Resumen general del sistema de pr&#233;stamos" FontSize="13"
                               Foreground="#475569" Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Column="2" Width="40" Height="40" CornerRadius="20"
                        Background="#E2E8F0" VerticalAlignment="Center">
                    <Viewbox Width="18" Height="18">
                        <Path Data="M9,9 C11.21,9 13,7.21 13,5 C13,2.79 11.21,1 9,1 C6.79,1 5,2.79 5,5 C5,7.21 6.79,9 9,9 Z M9,11 C6.33,11 1,12.34 1,15 L1,17 L17,17 L17,15 C17,12.34 11.67,11 9,11 Z" Fill="#334155" Stretch="Uniform"/>
                    </Viewbox>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="22" Background="#EFF6FF">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M9,9 C11.21,9 13,7.21 13,5 C13,2.79 11.21,1 9,1 C6.79,1 5,2.79 5,5 C5,7.21 6.79,9 9,9 Z M9,11 C6.33,11 1,12.34 1,15 L1,17 L17,17 L17,15 C17,12.34 11.67,11 9,11 Z" Fill="#3B82F6" Stretch="Uniform"/>
                                </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalClientes}" FontSize="26" FontWeight="Bold"
                                           Foreground="#0F172A"/>
                                <TextBlock Text="{Binding SubtituloClientes}" FontSize="12" Foreground="#475569"/>
                            </StackPanel>
                        </Grid>
                        <lvc:CartesianChart Series="{Binding SparklineClientes}"
                                            XAxes="{Binding EjeVacio}" YAxes="{Binding EjeVacio}"
                                            TooltipPosition="Hidden" ZoomMode="None"
                                            Height="35" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding IncrementoClientes}" FontSize="11" Foreground="#3B82F6"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="22" Background="#ECFDF5">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M10,2 C4.48,2 0,6.48 0,12 C0,17.52 4.48,22 10,22 C15.52,22 20,17.52 20,12 C20,6.48 15.52,2 10,2 Z M11,17 L9,17 L9,15 L11,15 Z M11,13 L9,13 L9,7 L11,7 Z" Fill="#10B981" Stretch="Uniform"/>
                                </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalPrestamos}" FontSize="26" FontWeight="Bold"
                                           Foreground="#0F172A"/>
                                <TextBlock Text="{Binding SubtituloPrestamos}" FontSize="12" Foreground="#475569"/>
                            </StackPanel>
                        </Grid>
                        <lvc:CartesianChart Series="{Binding SparklinePrestamos}"
                                            XAxes="{Binding EjeVacio}" YAxes="{Binding EjeVacio}"
                                            TooltipPosition="Hidden" ZoomMode="None"
                                            Height="35" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding IncrementoPrestamos}" FontSize="11" Foreground="#10B981"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="22" Background="#FFFBEB">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M16,6 L13,11 L10,8 L5,13 L6.5,14.5 L10,11 L13,14 L18,7 Z" Fill="#F59E0B" Stretch="Uniform"/>
                                </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalMonto}" FontSize="26" FontWeight="Bold"
                                           Foreground="#0F172A"/>
                                <TextBlock Text="{Binding SubtituloMonto}" FontSize="12" Foreground="#475569"/>
                            </StackPanel>
                        </Grid>
                        <lvc:CartesianChart Series="{Binding SparklineMonto}"
                                            XAxes="{Binding EjeVacio}" YAxes="{Binding EjeVacio}"
                                            TooltipPosition="Hidden" ZoomMode="None"
                                            Height="35" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding IncrementoMonto}" FontSize="11" Foreground="#F59E0B"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="22" Background="#F5F3FF">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M18,4 L4,4 C2.89,4 2,4.89 2,6 L2,18 C2,19.11 2.89,20 4,20 L18,20 C19.11,20 20,19.11 20,18 L20,6 C20,4.89 19.11,4 18,4 Z M18,18 L4,18 L4,12 L18,12 Z M18,8 L4,8 L4,6 L18,6 Z" Fill="#8B5CF6" Stretch="Uniform"/>
                                </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalPagos}" FontSize="26" FontWeight="Bold"
                                           Foreground="#0F172A"/>
                                <TextBlock Text="{Binding SubtituloPagos}" FontSize="12" Foreground="#475569"/>
                            </StackPanel>
                        </Grid>
                        <lvc:CartesianChart Series="{Binding SparklinePagos}"
                                            XAxes="{Binding EjeVacio}" YAxes="{Binding EjeVacio}"
                                            TooltipPosition="Hidden" ZoomMode="None"
                                            Height="35" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding IncrementoPagos}" FontSize="11" Foreground="#8B5CF6"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <TextBlock Text="Estado de Pr&#233;stamos" FontSize="18" FontWeight="Bold"
                                   Foreground="#0F172A" Margin="0,0,0,5"/>
                        <TextBlock Text="Distribuci&#243;n actual" FontSize="12" Foreground="#475569"
                                   Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding SeriesEstados}"
                                      Height="240" TooltipPosition="Hidden" Margin="0,0,0,10"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="3" Background="#10B981" Margin="0,0,0,3"/>
                                <TextBlock Text="Activos" FontSize="11" Foreground="#334155"/>
                                <TextBlock Text="{Binding ActivosCount}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="3" Background="#3B82F6" Margin="0,0,0,3"/>
                                <TextBlock Text="Pagados" FontSize="11" Foreground="#334155"/>
                                <TextBlock Text="{Binding PagadosCount}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="3" Background="#EF4444" Margin="0,0,0,3"/>
                                <TextBlock Text="En Mora" FontSize="11" Foreground="#334155"/>
                                <TextBlock Text="{Binding MoraCount}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <TextBlock Text="Pr&#243;ximos Vencimientos" FontSize="18" FontWeight="Bold"
                                   Foreground="#0F172A" Margin="0,0,0,5"/>
                        <TextBlock Text="Cuotas por vencer en los pr&#243;ximos d&#237;as" FontSize="12"
                                   Foreground="#475569" Margin="0,0,0,15"/>
                        <ListBox ItemsSource="{Binding Vencimientos}" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="48" Margin="0,0,0,2" CornerRadius="8" Background="#F8FAFC">
                                        <Grid Margin="12,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Cliente}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                <TextBlock Text="{Binding Fecha}" FontSize="11" Foreground="#475569"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Monto}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Border Grid.Column="2" CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" Background="#FEF3C7" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Estado}" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{Binding ColorBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <TextBlock Text="Acciones R&#225;pidas" FontSize="18" FontWeight="Bold"
                                   Foreground="#0F172A" Margin="0,0,0,5"/>
                        <TextBlock Text="Operaciones frecuentes" FontSize="12" Foreground="#475569" Margin="0,0,0,15"/>

                        <Button Command="{Binding NuevoClienteCommand}" Style="{StaticResource BotonAccion}" Background="#3B82F6">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="+" FontSize="22" FontWeight="Bold" Grid.Column="0"/>
                                <TextBlock Text="Nuevo Cliente" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NuevoPrestamoCommand}" Style="{StaticResource BotonAccion}" Background="#10B981">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="+" FontSize="22" FontWeight="Bold" Grid.Column="0"/>
                                <TextBlock Text="Nuevo Pr&#233;stamo" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding RegistrarPagoCommand}" Style="{StaticResource BotonAccion}" Background="#F59E0B">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="$" FontSize="20" FontWeight="Bold" Grid.Column="0"/>
                                <TextBlock Text="Registrar Pago" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding ReporteMoraCommand}" Style="{StaticResource BotonAccion}" Background="#8B5CF6">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="!" FontSize="22" FontWeight="Bold" Grid.Column="0"/>
                                <TextBlock Text="Reporte de Mora" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <TextBlock Text="Pr&#233;stamos Recientes" FontSize="18" FontWeight="Bold"
                                   Foreground="#0F172A" Margin="0,0,0,15"/>
                        <DataGrid ItemsSource="{Binding PrestamosRecientes}"
                                  AutoGenerateColumns="False" BorderThickness="0"
                                  Background="Transparent" HeadersVisibility="Column"
                                  RowHeaderWidth="0" GridLinesVisibility="None"
                                  IsReadOnly="True" Height="240" RowHeight="42" FontSize="13">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#334155"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Height" Value="36"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CLIENTE" Binding="{Binding Cliente}" Width="*"/>
                                <DataGridTextColumn Header="MONTO" Binding="{Binding Monto}" Width="100"/>
                                <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha}" Width="110"/>
                                <DataGridTemplateColumn Header="ESTADO" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                                    Background="{Binding ColorBrushLight}">
                                                <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding ColorBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="16" Margin="6"
                        Padding="20" Effect="{StaticResource SombraTarjeta}">
                    <StackPanel>
                        <TextBlock Text="Distribuci&#243;n por Frecuencia" FontSize="18" FontWeight="Bold"
                                   Foreground="#0F172A" Margin="0,0,0,5"/>
                        <TextBlock Text="Frecuencia de pagos" FontSize="12" Foreground="#475569" Margin="0,0,0,15"/>
                        <lvc:CartesianChart Series="{Binding SeriesFrecuencia}"
                                            XAxes="{Binding EjesFrecuenciaX}"
                                            YAxes="{Binding EjesFrecuenciaY}"
                                            Height="240" TooltipPosition="Hidden" ZoomMode="None"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
