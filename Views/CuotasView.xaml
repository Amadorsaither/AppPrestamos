<UserControl x:Class="AppPrestamos.Views.CuotasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F6FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Administración de Cuotas"
                   FontSize="30" FontWeight="Bold" Foreground="#0F172A"
                   Margin="0,0,0,20"/>

        <!-- Filtros -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Seleccionar Préstamo" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Prestamos}"
                              SelectedItem="{Binding PrestamoSeleccionado}"
                              Height="35">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="#"/><Run Text="{Binding Id}"/><Run Text=" - "/><Run Text="{Binding Cliente.Nombre}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Estado" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding EstadosFiltro}"
                              SelectedItem="{Binding FiltroEstado}"
                              Height="35" Width="120"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Recargar"
                        Command="{Binding RecargarCommand}"
                        Background="#3B82F6" Foreground="White"
                        Height="35" Width="100" Margin="0,20,0,0"
                        FontWeight="SemiBold" BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Tabla de cuotas -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Cuotas" FontSize="18" FontWeight="SemiBold"
                           Foreground="#0F172A" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Cuotas}"
                          SelectedItem="{Binding CuotaSeleccionada}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N°" Binding="{Binding NumeroCuota}" Width="50"/>
                        <DataGridTextColumn Header="Vencimiento" Binding="{Binding FechaVencimiento, StringFormat=dd/MM/yyyy}" Width="120"/>
                        <DataGridTextColumn Header="Capital" Binding="{Binding Capital, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Interés" Binding="{Binding Interes, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Mora" Binding="{Binding Mora, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding MontoTotal, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Saldo" Binding="{Binding SaldoPendiente, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
