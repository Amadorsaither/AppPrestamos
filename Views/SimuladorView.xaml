<UserControl x:Class="AppPrestamos.Views.SimuladorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F6FB">
    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
        <StackPanel Margin="20,25,20,30">

            <TextBlock Text="Simulador de Préstamos" FontSize="30" FontWeight="Bold" Foreground="#0F172A"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Calcule cuotas antes de crear un préstamo" FontSize="13" Foreground="#475569"
                       Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                    Effect="{StaticResource SombraTarjeta}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Monto *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="10,8">
                            <TextBox Text="{Binding Monto, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                     BorderThickness="0" Background="Transparent" Foreground="#0F172A"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,5,15">
                        <TextBlock Text="Tasa de Interés (%) *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="10,8">
                            <TextBox Text="{Binding TasaInteres, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                     BorderThickness="0" Background="Transparent" Foreground="#0F172A"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,15">
                        <TextBlock Text="Número de Cuotas *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="10,8">
                            <TextBox Text="{Binding NumeroCuotas, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                     BorderThickness="0" Background="Transparent" Foreground="#0F172A"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Tipo de Interés" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="8,4">
                            <ComboBox ItemsSource="{Binding TiposInteres}" SelectedIndex="{Binding TipoInteresSeleccionado}"
                                      FontSize="14" BorderThickness="0" Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,0,5,15">
                        <TextBlock Text="Frecuencia de Pago" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="8,4">
                            <ComboBox ItemsSource="{Binding Frecuencias}" SelectedIndex="{Binding FrecuenciaSeleccionada}"
                                      FontSize="14" BorderThickness="0" Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="10,0,0,15" VerticalAlignment="Bottom">
                        <Button Command="{Binding CalcularCommand}" Height="42"
                                Background="#3B82F6" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" Content="Calcular"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0"
                          Visibility="{Binding HayResultado, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="8" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Monto Total" FontSize="11" Foreground="#475569"/>
                                <TextBlock Text="{Binding MontoTotal, StringFormat=${0:N2}}" FontSize="18"
                                           FontWeight="Bold" Foreground="#3B82F6"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="8" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Total Intereses" FontSize="11" Foreground="#475569"/>
                                <TextBlock Text="{Binding TotalIntereses, StringFormat=${0:N2}}" FontSize="18"
                                           FontWeight="Bold" Foreground="#10B981"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#FFFBEB" CornerRadius="8" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Valor por Cuota" FontSize="11" Foreground="#475569"/>
                                <TextBlock Text="{Binding ValorCuota, StringFormat=${0:N2}}" FontSize="18"
                                           FontWeight="Bold" Foreground="#F59E0B"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="0"
                    Visibility="{Binding HayResultado, Converter={StaticResource BoolToVisibilityConverter}}"
                    Effect="{StaticResource SombraTarjeta}">
                <StackPanel>
                    <TextBlock Text="Tabla de Amortización" FontSize="16" FontWeight="SemiBold"
                               Foreground="#0F172A" Margin="20,15,20,10"/>
                    <DataGrid ItemsSource="{Binding CuotasSimuladas}"
                              AutoGenerateColumns="False" BorderThickness="0"
                              Background="Transparent" HeadersVisibility="Column"
                              RowHeaderWidth="0" GridLinesVisibility="None"
                              IsReadOnly="True" RowHeight="34" FontSize="12">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#334155"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Height" Value="34"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CUOTA" Binding="{Binding Numero}" Width="70"/>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha}" Width="100"/>
                            <DataGridTextColumn Header="CAPITAL" Binding="{Binding Capital, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="INTERÉS" Binding="{Binding Interes, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="SALDO" Binding="{Binding Saldo, StringFormat=N2}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
