<Window x:Class="AppPrestamos.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iniciar Sesión"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="16" Background="#F1F5F9" Padding="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="160"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0F172A" CornerRadius="16,16,0,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="White" Margin="0,0,0,10">
                        <TextBlock Text="P" FontSize="28" FontWeight="Bold"
                                   Foreground="#0F172A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Préstamos App" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Gestión Financiera" FontSize="12"
                               Foreground="#475569" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="35,25,35,25" VerticalAlignment="Top">
                <TextBlock Text="Iniciar Sesión" FontSize="18" FontWeight="Bold"
                           Foreground="#0F172A" Margin="0,0,0,20"/>

                <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Background="White" Padding="12,10" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Usuario" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtUsuario" Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" BorderThickness="0" Background="Transparent"
                                 Foreground="#0F172A" Padding="0"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Background="White" Padding="12,10" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Contraseña" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="TxtContrasena"
                                     FontSize="14" BorderThickness="0" Background="Transparent"
                                     Foreground="#0F172A" Padding="0"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorBorder" CornerRadius="8" Background="#FEF2F2"
                        BorderBrush="#FECACA" BorderThickness="1"
                        Padding="12,8" Margin="0,0,0,14"
                        Visibility="{Binding HayError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMensaje}" FontSize="12"
                               Foreground="#DC2626"/>
                </Border>

                <Border CornerRadius="10" Background="#3B82F6" Height="46">
                    <Button Click="BtnIniciarSesion_Click"
                            Background="Transparent" Foreground="White"
                            FontSize="15" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Height="46"
                            Content="Iniciar Sesión"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
