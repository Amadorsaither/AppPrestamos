<Window x:Class="AppPrestamos.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iniciar Sesión"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="16" Background="#F1F5F9" Padding="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="160"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0F172A" CornerRadius="16,16,0,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="White" Margin="0,0,0,10">
                        <TextBlock Text="P" FontSize="28" FontWeight="Bold"
                                   Foreground="#0F172A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Préstamos App" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Gestión Financiera" FontSize="12"
                               Foreground="#475569" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="35,25,35,25" VerticalAlignment="Top">
                <TextBlock Text="Iniciar Sesión" FontSize="18" FontWeight="Bold"
                           Foreground="#0F172A" Margin="0,0,0,20"/>

                <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Background="White" Padding="12,10" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Usuario" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtUsuario" Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" BorderThickness="0" Background="Transparent"
                                 Foreground="#0F172A" Padding="0"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                        Background="White" Padding="12,10" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Contraseña" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                        <Grid>
                            <PasswordBox x:Name="TxtContrasena"
                                         FontSize="14" BorderThickness="0" Background="Transparent"
                                         Foreground="#0F172A" Padding="0,0,24,0"/>
                            <TextBox x:Name="TxtContrasenaVisible"
                                     Text="{Binding Contrasena, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" BorderThickness="0" Background="Transparent"
                                     Foreground="#0F172A" Padding="0,0,24,0"
                                     Visibility="Collapsed"/>
                            <Button x:Name="BtnTogglePass" Width="22" Height="22"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="BtnTogglePass_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="IconEye" Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z M12,17C9.24,17 7,14.76 7,12C7,9.24 9.24,7 12,7C14.76,7 17,9.24 17,12C17,14.76 14.76,17 12,17Z M12,9C10.34,9 9,10.34 9,12C9,13.66 10.34,15 12,15C13.66,15 15,13.66 15,12C15,10.34 13.66,9 12,9Z"
                                              Fill="#475569" Stretch="Uniform"/>
                                        <Path x:Name="IconEyeOff" Data="M2,2L22,22M10.41,10.41C9.46,10.97 8.72,11.85 8.35,12.88C8.24,13.17 8.17,13.47 8.14,13.78C8.08,14.5 8.18,15.18 8.45,15.8M22,12C20.27,16.39 16,19.5 11,19.5C9.87,19.5 8.78,19.34 7.74,19.02M15.12,15.12C14.07,16.17 12.59,16.83 11,16.83C10.12,16.83 9.28,16.6 8.55,16.2M19.9,4.1L17.77,6.23C16.23,4.95 14.23,4.14 12,4.14C7,4.14 2.73,7.26 1,12C1.97,14.47 3.82,16.5 6.14,17.83L4.08,19.9"
                                              Fill="#475569" Stretch="Uniform" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorBorder" CornerRadius="8" Background="#FEF2F2"
                        BorderBrush="#FECACA" BorderThickness="1"
                        Padding="12,8" Margin="0,0,0,14"
                        Visibility="{Binding HayError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMensaje}" FontSize="12"
                               Foreground="#DC2626"/>
                </Border>

                <Border CornerRadius="10" Background="#3B82F6" Height="46">
                    <Button Click="BtnIniciarSesion_Click"
                            Background="Transparent" Foreground="White"
                            FontSize="15" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Height="46"
                            Content="Iniciar Sesión"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
