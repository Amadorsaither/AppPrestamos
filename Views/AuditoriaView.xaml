<UserControl x:Class="AppPrestamos.Views.AuditoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F6FB">
    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
        <StackPanel Margin="20,25,20,30">

            <TextBlock Text="Auditoría" FontSize="30" FontWeight="Bold" Foreground="#0F172A"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Registro de actividades del sistema" FontSize="13" Foreground="#475569"
                       Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20"
                    Effect="{StaticResource SombraTarjeta}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="#F8FAFC" Padding="10,8" Margin="0,0,10,0">
                        <TextBox Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" BorderThickness="0" Background="Transparent"
                                 Foreground="#0F172A">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Text" Value="Buscar en auditoría..."/>
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="Text" Value=""/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="White" Padding="8,4" Margin="0,0,10,0" Width="120">
                        <ComboBox ItemsSource="{Binding Acciones}" SelectedItem="{Binding FiltroAccion}"
                                  FontSize="13" BorderThickness="0" Background="Transparent"/>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="White" Padding="8,4" Width="120">
                        <ComboBox ItemsSource="{Binding Entidades}" SelectedItem="{Binding FiltroEntidad}"
                                  FontSize="13" BorderThickness="0" Background="Transparent"/>
                    </Border>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="0"
                    Effect="{StaticResource SombraTarjeta}">
                <DataGrid ItemsSource="{Binding Registros}"
                          AutoGenerateColumns="False" BorderThickness="0"
                          Background="Transparent" HeadersVisibility="Column"
                          RowHeaderWidth="0" GridLinesVisibility="None"
                          IsReadOnly="True" RowHeight="36" FontSize="12"
                          MaxHeight="600">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#334155"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#0F172A"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="USUARIO" Binding="{Binding UsuarioNombre}" Width="120"/>
                        <DataGridTextColumn Header="ACCIÓN" Binding="{Binding Accion}" Width="90"/>
                        <DataGridTextColumn Header="ENTIDAD" Binding="{Binding Entidad}" Width="100"/>
                        <DataGridTextColumn Header="ID" Binding="{Binding EntidadId}" Width="60"/>
                        <DataGridTextColumn Header="DETALLE" Binding="{Binding Detalle}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
