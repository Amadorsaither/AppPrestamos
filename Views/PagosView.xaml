<UserControl x:Class="AppPrestamos.Views.PagosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F6FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Registro de Pagos"
                   FontSize="30" FontWeight="Bold" Foreground="#0F172A"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <Border Background="#FEF2F2" CornerRadius="8" Padding="10" Margin="0,0,0,10"
                        BorderBrush="#FECACA" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TieneError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorFormulario}" Foreground="#DC2626" FontSize="12"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Cuota a Pagar" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding CuotasPendientes}"
                                  SelectedItem="{Binding CuotaSeleccionada}"
                                  Height="35">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="Préstamo #"/><Run Text="{Binding PrestamoId}"/>
                                        <Run Text=" - Cuota #"/><Run Text="{Binding NumeroCuota}"/>
                                        <Run Text=" - $"/><Run Text="{Binding SaldoPendiente, StringFormat=N2}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Monto a Pagar *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MontoAPagar, ValidatesOnNotifyDataErrors=True, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Observación" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Observacion}" Height="35"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Registrar Pago"
                            Command="{Binding RegistrarPagoCommand}"
                            Background="#10B981" Foreground="White"
                            Height="35" Width="130" Margin="5,20,5,0"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Historial de Pagos" FontSize="18" FontWeight="SemiBold"
                               Foreground="#0F172A" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Eliminar Pago"
                            Command="{Binding EliminarPagoCommand}"
                            Background="#EF4444" Foreground="White"
                            Height="32" Width="110"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Pagos}"
                          SelectedItem="{Binding PagoSeleccionado}"
                          AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10,0,0"
                          BorderThickness="0" Background="Transparent"
                          HeadersVisibility="Column" RowHeaderWidth="0"
                          GridLinesVisibility="None" FontSize="13" RowHeight="38">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#334155"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#0F172A"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="PRÉSTAMO" Binding="{Binding Cuota.PrestamoId}" Width="70"/>
                        <DataGridTextColumn Header="CUOTA N°" Binding="{Binding Cuota.NumeroCuota}" Width="70"/>
                        <DataGridTextColumn Header="FECHA" Binding="{Binding FechaPago, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="MONTO" Binding="{Binding MontoPagado, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="OBSERVACIÓN" Binding="{Binding Observacion}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
