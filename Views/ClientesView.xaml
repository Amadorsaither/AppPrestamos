<UserControl x:Class="AppPrestamos.Views.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F6FB" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Gestión de Clientes"
                       FontSize="30" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding TotalClientes}" FontSize="13" Foreground="#475569" Margin="0,3,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FEF2F2" CornerRadius="8"
                        Padding="10" Margin="0,0,0,10"
                        BorderBrush="#FECACA" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TieneError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorFormulario}" Foreground="#DC2626" FontSize="12"/>
                </Border>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Nombre *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Nombre, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Height="35"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Cédula *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Cedula, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Height="35"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                    <TextBlock Text="Teléfono *" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Telefono, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                             Height="35"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                    <TextBlock Text="Dirección" Foreground="#334155" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Direccion}" Height="35"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="5,10,5,0">
                    <Button Content="{Binding TextoBotonGuardar}"
                            Command="{Binding GuardarCommand}"
                            Background="#3B82F6" Foreground="White"
                            Height="40" Width="160"
                            FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="Cancelar"
                            Command="{Binding CancelarEdicionCommand}"
                            Background="#E2E8F0" Foreground="#475569"
                            Height="40" Width="120"
                            FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EstaEditando}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                             Height="32" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="Editar"
                            Command="{Binding EditarCommand}"
                            Background="#3B82F6" Foreground="White"
                            Height="32" Width="80" Margin="0,0,5,0"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    <Button Grid.Column="2" Content="Eliminar"
                            Command="{Binding EliminarCommand}"
                            Background="#EF4444" Foreground="White"
                            Height="32" Width="80"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Clientes}"
                          SelectedItem="{Binding ClienteSeleccionado}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          BorderThickness="0" Background="Transparent"
                          HeadersVisibility="Column" RowHeaderWidth="0"
                          GridLinesVisibility="None" FontSize="13" RowHeight="38">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#334155"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#0F172A"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="CÉDULA" Binding="{Binding Cedula}" Width="130"/>
                        <DataGridTextColumn Header="TELÉFONO" Binding="{Binding Telefono}" Width="130"/>
                        <DataGridTextColumn Header="DIRECCIÓN" Binding="{Binding Direccion}" Width="*"/>
                        <DataGridTextColumn Header="REGISTRO" Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
