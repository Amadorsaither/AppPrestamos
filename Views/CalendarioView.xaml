<UserControl x:Class="AppPrestamos.Views.CalendarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F6FB">
    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
        <StackPanel Margin="20,25,20,30">

            <TextBlock Text="Calendario de Pagos" FontSize="30" FontWeight="Bold" Foreground="#0F172A"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Visualice los pagos programados por fecha" FontSize="13" Foreground="#475569"
                       Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20"
                    Effect="{StaticResource SombraTarjeta}">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding MesAnteriorCommand}"
                                Background="#F1F5F9" BorderThickness="1" BorderBrush="#E2E8F0"
                                Padding="10,6" Cursor="Hand" FontSize="14" Foreground="#475569"
                                Content="◀ Anterior"/>

                        <TextBlock Grid.Column="1" Text="{Binding TituloMes}" FontSize="18" FontWeight="Bold"
                                   Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Button Grid.Column="2" Command="{Binding MesSiguienteCommand}"
                                Background="#F1F5F9" BorderThickness="1" BorderBrush="#E2E8F0"
                                Padding="10,6" Cursor="Hand" FontSize="14" Foreground="#475569"
                                Content="Siguiente ▶"/>
                    </Grid>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dom" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Lun" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Mar" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Mié" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Jue" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Vie" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="Sáb" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center" Padding="0,0,0,8"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Dias}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" BorderThickness="0.5" Padding="6"
                                        Height="75" Background="{Binding ColorFondo}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TextoNumero}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{Binding ColorNumero}"/>
                                        <Border CornerRadius="8" Height="4" Width="16"
                                                Margin="0,6,0,0" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TienePago}" Value="True">
                                                            <Setter Property="Background" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20"
                    Effect="{StaticResource SombraTarjeta}">
                <StackPanel>
                    <TextBlock Text="Detalle del Día" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"
                               Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding PagosDelDia}"
                              AutoGenerateColumns="False" BorderThickness="0"
                              Background="Transparent" HeadersVisibility="Column"
                              RowHeaderWidth="0" GridLinesVisibility="None"
                              IsReadOnly="True" RowHeight="34" FontSize="12">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#334155"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Height" Value="34"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding Cliente}" Width="*"/>
                            <DataGridTextColumn Header="MONTO" Binding="{Binding Monto, StringFormat=N2}" Width="120"/>
                            <DataGridTemplateColumn Header="ESTADO" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Estado}" FontWeight="SemiBold"
                                                   Foreground="{Binding ColorEstado}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
