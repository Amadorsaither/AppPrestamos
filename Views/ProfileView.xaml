<UserControl x:Class="AppPrestamos.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AppPrestamos.ViewModels"
             Background="#F1F5F9">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <ScrollViewer>
        <StackPanel Margin="40,30">
            <TextBlock Text="Mi Perfil" FontSize="28" FontWeight="Bold"
                       Foreground="#0F172A" Margin="0,0,0,30"/>

            <Border Background="White" CornerRadius="16" Padding="30"
                    Effect="{StaticResource SombraTarjeta}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40"
                            Background="#3B82F6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Inicial}" FontSize="32"
                                   FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding NombreUsuario}" FontSize="22" FontWeight="Bold"
                                   Foreground="#0F172A"/>
                        <TextBlock Text="{Binding Rol}" FontSize="14" Foreground="#3B82F6"
                                   FontWeight="SemiBold" Margin="0,4,0,0"/>
                        <TextBlock FontSize="12" Foreground="#475569" Margin="0,4,0,0">
                            <Run Text="Miembro desde "/>
                            <Run Text="{Binding FechaCreacion, StringFormat={}{0:dd/MM/yyyy}}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="16" Padding="30"
                    Effect="{StaticResource SombraTarjeta}">
                <StackPanel>
                    <TextBlock Text="Cambiar Contraseña" FontSize="20" FontWeight="Bold"
                               Foreground="#0F172A" Margin="0,0,0,20"/>

                    <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="#F8FAFC" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Contraseña Actual" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtContrasenaActual"
                                         FontSize="14" BorderThickness="0" Background="Transparent"
                                         Foreground="#0F172A" Padding="0"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="#F8FAFC" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Nueva Contraseña" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtNuevaContrasena"
                                         FontSize="14" BorderThickness="0" Background="Transparent"
                                         Foreground="#0F172A" Padding="0"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"
                            Background="#F8FAFC" Padding="12,10" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Confirmar Nueva Contraseña" FontSize="11" Foreground="#334155" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtConfirmarContrasena"
                                         FontSize="14" BorderThickness="0" Background="Transparent"
                                         Foreground="#0F172A" Padding="0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="MensajeError" CornerRadius="8" Background="#FEF2F2"
                            BorderBrush="#FECACA" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock x:Name="MensajeErrorText" FontSize="12" Foreground="#DC2626"/>
                    </Border>
                    <Border x:Name="MensajeExito" CornerRadius="8" Background="#ECFDF5"
                            BorderBrush="#A7F3D0" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock x:Name="MensajeExitoText" FontSize="12" Foreground="#16A34A"/>
                    </Border>

                    <Border CornerRadius="10" Background="#3B82F6" Height="44" HorizontalAlignment="Left" Width="220">
                        <Button Click="BtnCambiarContrasena_Click"
                                Background="Transparent" Foreground="White"
                                FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" Height="44"
                                Content="Cambiar Contraseña"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
