                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    Simulador
                                </TextBlock>
                            </Grid>
                        </Button>
                    </Border>

