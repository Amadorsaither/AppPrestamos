                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Simulador">
                                        <Setter Property="Background" Value="#3B82F6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding NavigateToSimuladorCommand}"
                                Cursor="Hand" Height="44" VerticalAlignment="Center">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="18" Height="18" Grid.Column="0">
                                    <Path Data="{StaticResource IconSimulador}" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="#475569"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Simulador">
                                                        <Setter Property="Fill" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
