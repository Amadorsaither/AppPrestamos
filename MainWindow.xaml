                    </Border>

                    <Border Height="44" Margin="0,2" CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Reportes">
