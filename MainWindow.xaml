                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="25,30,25,20">
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="White" Opacity="0.95"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Border CornerRadius="28" Background="#3B82F6" Margin="3">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconPrestamos}" Fill="White" Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Border>
                    <TextBlock Text="Pr&#233;stamos App" Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Gesti&#243;n Financiera" Foreground="#475569" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12,0,12,0">
                    <Border Height="44" Margin="0,2" CornerRadius="10">
