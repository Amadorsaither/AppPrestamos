                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    Cuotas
                                </TextBlock>
                            </Grid>
                        </Button>
                    </Border>

                    <Border Height="44" Margin="0,2" CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Pagos">
                                        <Setter Property="Background" Value="#3B82F6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding NavigateToPagosCommand}"
                                Cursor="Hand" Height="44" VerticalAlignment="Center">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="18" Height="18" Grid.Column="0">
                                    <Path Data="{StaticResource IconPagos}" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="#475569"/>
                                                <Style.Triggers>
