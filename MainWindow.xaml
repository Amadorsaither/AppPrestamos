                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Viewbox>
                                <TextBlock Grid.Column="1" FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="Reportes">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    Reportes
                                </TextBlock>
                            </Grid>
                        </Button>
                    </Border>

                    <Separator BorderBrush="#334155" Margin="14,6,14,6"/>

                    <Border Height="44" Margin="0,2" CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Backup">
                                        <Setter Property="Background" Value="#3B82F6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding NavigateToBackupCommand}"
                                Cursor="Hand" Height="44" VerticalAlignment="Center">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="18" Height="18" Grid.Column="0">
                                    <Path Data="{StaticResource IconBackup}" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="#475569"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Backup">
                                                        <Setter Property="Fill" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Viewbox>
                                <TextBlock Grid.Column="1" FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="Backup">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    Respaldo
                                </TextBlock>
                            </Grid>
                        </Button>
                    </Border>

                    <Border Height="44" Margin="0,2" CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Auditoria">
                                        <Setter Property="Background" Value="#3B82F6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding NavigateToAuditoriaCommand}"
                                Cursor="Hand" Height="44" VerticalAlignment="Center">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="18" Height="18" Grid.Column="0">
                                    <Path Data="{StaticResource IconAuditoria}" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="#475569"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Auditoria">
                                                        <Setter Property="Fill" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Viewbox>
                                <TextBlock Grid.Column="1" FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="Auditoria">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
